jinx_name: run_terminal
description: Run a command in a terminal pane. Defaults to the active terminal pane.
inputs:
  - command
  - { pane_id: "active" }
steps:
  - name: run_terminal
    engine: incognide
    action: run_terminal
    args:
      command: "{{ command }}"
      paneId: "{{ pane_id }}"
